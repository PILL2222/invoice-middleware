# ── Server ────────────────────────────────────────────
PORT=3000
NODE_ENV=production
LOG_LEVEL=info

# ── Telegram Bot ──────────────────────────────────────
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=123456789:AABBCCDDEEFFaabbccddeeff

# ID of the invoice group (negative number for groups, e.g. -1001234567890)
# To find: add @userinfobot to the group and it will show the chat ID
TELEGRAM_GROUP_ID=-1001234567890

# ── LiveChat ──────────────────────────────────────────
# Your LiveChat account email
LIVECHAT_ACCOUNT_ID=your@email.com

# Personal Access Token from LiveChat console
LIVECHAT_PAT=your_personal_access_token

# Group ID to transfer unmatched chats to (0 = default group)
LIVECHAT_AGENT_GROUP_ID=0

# Webhook secret (set this in LiveChat webhook settings)
LIVECHAT_WEBHOOK_SECRET=your_webhook_secret_here

# Region: fra (Europe) or dal (Americas)
LIVECHAT_REGION=fra

# ── Security ──────────────────────────────────────────
# Comma-separated list of allowed origins for CORS
ALLOWED_ORIGINS=https://yourdomain.com

# ── Public URL (for Telegram webhook setup) ───────────
PUBLIC_URL=https://your-server.com
